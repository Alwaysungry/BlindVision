.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.cer
credentials.json
secrets.yaml
secrets.yml
api_key*
apikey*
*secret*
*password*
*credential*

# -------------------------------------------
# 本地配置文件
# -------------------------------------------
local.properties
*.properties
!gradle.properties
!settings.gradle.kts
!build.gradle.kts

# -------------------------------------------
# Python 虚拟环境
# -------------------------------------------
blind-vision-core/.venv/
venv/
env/
.venv/
ENV/
env.bak/
venv.bak/

